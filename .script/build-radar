#!/bin/bash
# build-radar - Build all radar packages (radar_lidar, radar_camera, radar_fusion, radar_bridge, radar_calibration, radar_bringup)
# Usage: build-radar [Release|Debug]
set -euo pipefail

: "${RADAR_WS:=/workspace}"

BUILD_TYPE="${1:-Release}"
cd "${RADAR_WS}/ros_ws"

if [ -f /opt/ros/jazzy/setup.bash ]; then
    set +u
    source /opt/ros/jazzy/setup.bash
    set -u
else
    echo "[ERROR] ROS2 Jazzy not found at /opt/ros/jazzy/setup.bash" >&2
    exit 1
fi

echo "[BUILD] radar packages (${BUILD_TYPE})..."
colcon build \
    --packages-select radar_lidar radar_camera radar_fusion radar_bridge radar_calibration radar_bringup \
    --cmake-args -DCMAKE_BUILD_TYPE=${BUILD_TYPE} -DCMAKE_EXPORT_COMPILE_COMMANDS=1 \
        -DCMAKE_CXX_FLAGS="-Wno-missing-field-initializers -Wno-unused-parameter"

echo "[OK] Build complete. Source install/setup.bash to use."
