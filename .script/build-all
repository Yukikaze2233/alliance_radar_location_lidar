#!/bin/bash
# build-all - Build all packages (third-party + main)
# Usage: build-all [Release|Debug]
set -euo pipefail

: "${RADAR_WS:=/workspace}"

BUILD_TYPE="${1:-Release}"
cd "${RADAR_WS}/ros_ws"

if [ -f /opt/ros/jazzy/setup.bash ]; then
    set +u
    source /opt/ros/jazzy/setup.bash
    set -u
else
    echo "[ERROR] ROS2 Jazzy not found at /opt/ros/jazzy/setup.bash" >&2
    exit 1
fi

_build() {
    colcon build "$@" 2>&1 | grep -vE "^(Summary:|  [0-9]+ package|WARNING:colcon|\[Processing|$|^-+$)"
    return "${PIPESTATUS[0]}"
}

_build --packages-select small_gicp hikcamera hikcamera_ros_driver \
    --cmake-args -DCMAKE_BUILD_TYPE=${BUILD_TYPE} -Wno-dev

_build --packages-select direct_visual_lidar_calibration \
    --cmake-args \
        -DCMAKE_BUILD_TYPE=${BUILD_TYPE} \
        -DCMAKE_CXX_STANDARD=17 \
        -DCMAKE_CXX_FLAGS="-Wno-maybe-uninitialized -Wno-template-id-cdtor" \
        -DCMAKE_POLICY_VERSION_MINIMUM=3.5 \
        -DCMAKE_POLICY_DEFAULT_CMP0167=NEW \
        -DCMAKE_POLICY_DEFAULT_CMP0144=NEW \
        -Wno-dev

_build --packages-select radar_lidar radar_camera radar_fusion radar_bridge radar_bringup radar_calibration \
    --cmake-args \
        -DCMAKE_BUILD_TYPE=${BUILD_TYPE} \
        -DCMAKE_CXX_FLAGS="-Wno-missing-field-initializers -Wno-unused-parameter" \
        -Wno-dev

echo ">>"
