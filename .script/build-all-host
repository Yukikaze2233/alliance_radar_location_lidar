#!/bin/bash
# build-all-host — build inside RADAR container, then export compile_commands for host clangd
# Usage: ./script/build-all-host [Release|Debug] [extra colcon args...]
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

echo "[build-all-host] Building in RADAR container..."
docker exec RADAR zsh -lc "build-all $@"

echo "[build-all-host] Exporting compile_commands for host clangd..."
"${SCRIPT_DIR}/export-compile-commands"

echo "[build-all-host] Done. Run :LspRestart in neovim to refresh clangd."
