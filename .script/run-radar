#!/bin/bash
# run-radar - Run radar_lidar_node
# Usage: run-radar [extra ros2 args...]
set -euo pipefail

: "${RADAR_WS:=/workspace}"

cd "${RADAR_WS}/ros_ws"

if [ -f /opt/ros/jazzy/setup.bash ]; then
    set +u
    source /opt/ros/jazzy/setup.bash
    set -u
else
    echo "[ERROR] ROS2 Jazzy not found at /opt/ros/jazzy/setup.bash" >&2
    exit 1
fi

if [ -f install/setup.bash ]; then
    set +u
    source install/setup.bash
    set -u
else
    echo "[ERROR] install/setup.bash not found. Run build-all or build-radar first." >&2
    exit 1
fi

echo "[RUN] radar_lidar_node..."
ros2 run radar_lidar radar_lidar_node --ros-args -p map_path:=${RADAR_WS}/model/generated/map.pcd "$@"
